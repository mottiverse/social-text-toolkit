---
export interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  i18nTitle?: string;
  i18nDesc?: string;
}

const { title, description, href, icon, i18nTitle, i18nDesc } = Astro.props;
---

<a href={href} class="tool-card group">
  <div class="flex items-start gap-3">
    <span class="text-2xl">{icon}</span>
    <div class="flex-1 min-w-0">
      <h3 class="font-semibold text-[var(--text-primary)] group-hover:text-brand-500 dark:group-hover:text-brand-400 transition-colors" data-i18n={i18nTitle}>
        {title}
      </h3>
      <p class="text-sm text-[var(--text-secondary)] mt-0.5" data-i18n={i18nDesc}>{description}</p>
    </div>
    <svg class="w-5 h-5 text-[var(--text-secondary)] opacity-0 group-hover:opacity-100 transition-opacity shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
  </div>
</a>
