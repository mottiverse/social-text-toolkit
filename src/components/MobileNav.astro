---
const currentPath = Astro.url.pathname;
const tabs = [
  { href: '/', label: 'Home', icon: '🏠', i18n: 'mnav.home' },
  { href: '/fancy-text-generator', label: 'Tools', icon: '🔧', i18n: 'mnav.tools' },
  { href: '/symbols', label: 'Symbols', icon: '✨', i18n: 'nav.symbols' },
  { href: '/favorites', label: 'Favorites', icon: '⭐', i18n: 'mnav.favorites' },
];
---

<nav class="fixed bottom-0 left-0 right-0 z-50 md:hidden border-t border-[var(--border-color)] bg-[var(--bg-primary)]/95 backdrop-blur-lg" style="padding-bottom: env(safe-area-inset-bottom)">
  <div class="flex items-center justify-around h-14">
    {tabs.map((tab) => {
      const isActive = tab.href === '/'
        ? currentPath === '/'
        : currentPath.startsWith(tab.href);
      return (
        <a
          href={tab.href}
          class:list={[
            'relative flex flex-col items-center gap-0.5 px-3 py-1.5 text-xs transition-colors',
            isActive
              ? 'text-brand-500 dark:text-brand-400'
              : 'text-[var(--text-secondary)] hover:text-brand-500 dark:hover:text-brand-400',
          ]}
        >
          <span class="text-lg leading-none">{tab.icon}</span>
          <span class="font-medium" data-i18n={tab.i18n}>{tab.label}</span>
          {tab.href === '/favorites' && <span id="fav-badge" class="absolute -top-0.5 -right-1 min-w-[1.125rem] h-[1.125rem] flex items-center justify-center rounded-full bg-brand-500 text-white text-[10px] font-bold px-1 hidden">0</span>}
        </a>
      );
    })}
  </div>
</nav>

<script>
  // Update favorites badge count
  const badge = document.getElementById('fav-badge');
  if (badge) {
    const count = window.getFavorites ? window.getFavorites().length : 0;
    if (count > 0) {
      badge.textContent = count > 99 ? '99+' : count;
      badge.classList.remove('hidden');
    }
  }
</script>
