---
import ToolLayout from '../layouts/ToolLayout.astro';
import { dividerCategories } from '../data/dividers.js';

const categoriesJson = JSON.stringify(dividerCategories);
---

<ToolLayout
  title="Text Dividers"
  description="Browse and copy 200+ decorative text dividers for your social media bios. Minimal, decorative, stars, floral, and fancy styles."
>
  <!-- Category Tabs -->
  <section class="px-4 pb-4">
    <div class="mb-4 p-3 rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)]">
      <div class="flex flex-wrap gap-2 text-xs">
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400">✓ Instagram</span>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400">✓ TikTok</span>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400">✓ Discord</span>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400">✓ Twitter/X</span>
      </div>
      <p class="text-xs text-[var(--text-secondary)] mt-1.5">Text dividers use Unicode box-drawing and decorative characters. They render correctly on all major social platforms. Some multi-line dividers may appear differently on mobile.</p>
    </div>
    <div id="category-tabs" role="tablist" class="flex gap-2 overflow-x-auto pb-2 scrollbar-hide">
      <button
        class="tab-btn active whitespace-nowrap px-4 py-2 rounded-full text-sm font-medium bg-brand-500 text-white dark:bg-brand-400 dark:text-gray-900 transition-all"
        data-category="all"
        role="tab"
        aria-selected="true"
      >All</button>
      {dividerCategories.map((cat) => (
        <button
          class="tab-btn whitespace-nowrap px-4 py-2 rounded-full text-sm font-medium border border-[var(--border-color)] text-[var(--text-secondary)] hover:border-brand-300 hover:text-brand-500 dark:hover:border-brand-600 dark:hover:text-brand-400 transition-all"
          data-category={cat.id}
          role="tab"
          aria-selected="false"
        >{cat.icon} {cat.name}</button>
      ))}
    </div>
  </section>

  <!-- Dividers List -->
  <section class="px-4 pb-8">
    <div id="divider-list" class="space-y-3">
    </div>
    <p id="no-results" class="text-center text-[var(--text-secondary)] py-8 hidden">No dividers found</p>
  </section>
</ToolLayout>

<script is:inline src="/scripts/tabs.js"></script>
<script define:vars={{ categoriesJson }}>
  const categories = JSON.parse(categoriesJson);
  let activeCategory = 'all';

  const dividerList = document.getElementById('divider-list');
  const noResults = document.getElementById('no-results');

  function renderDividers() {
    const matchedCategories = categories.filter(cat => {
      if (activeCategory !== 'all' && cat.id !== activeCategory) return false;
      return true;
    });

    const allDividers = [];
    for (const cat of matchedCategories) {
      for (const d of cat.dividers) {
        allDividers.push({ divider: d, category: cat.name });
      }
    }

    dividerList.innerHTML = allDividers.map((item, i) => `
      <button
        class="w-full p-4 rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)] hover:border-brand-300 dark:hover:border-brand-600 hover:shadow-sm active:scale-[0.99] transition-all cursor-pointer text-left group"
        data-copy="${item.divider.replace(/"/g, '&quot;').replace(/\n/g, '\\n')}"
      >
        <pre class="text-lg text-[var(--text-primary)] whitespace-pre-wrap break-all select-all font-sans leading-relaxed">${item.divider}</pre>
        <div class="flex justify-between items-center mt-2">
          <span class="text-[10px] text-[var(--text-secondary)]">${item.category}</span>
          <span class="text-xs text-brand-500 dark:text-brand-400 opacity-0 group-hover:opacity-100 transition-opacity">Click to copy</span>
        </div>
      </button>
    `).join('');

    noResults.classList.toggle('hidden', allDividers.length > 0);

    dividerList.querySelectorAll('[data-copy]').forEach(btn => {
      btn.addEventListener('click', () => {
        const raw = btn.getAttribute('data-copy').replace(/\\n/g, '\n');
        if (window.copyToClipboard) window.copyToClipboard(raw);
      });
    });
  }

  setupCategoryTabs('.tab-btn', (category) => {
    activeCategory = category;
    renderDividers();
  });

  renderDividers();
</script>
