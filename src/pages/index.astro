---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import { symbolCategories } from '../data/symbols.js';

// Pick popular symbols for the homepage showcase
const popularCategories = symbolCategories.slice(0, 4);
---

<BaseLayout title="Social Text Toolkit" description="Free online text generator, symbol library, invisible characters, kaomoji &amp; bio decorations for social media creators. Create aesthetic profiles on Instagram, TikTok, Discord.">
  <!-- Hero Section -->
  <section class="px-4 pt-8 pb-6 text-center">
    <h1 class="text-3xl md:text-4xl font-bold text-[var(--text-primary)] mb-3">
      Social Text Toolkit
    </h1>
    <p class="text-[var(--text-secondary)] text-base md:text-lg max-w-xl mx-auto mb-6">
      Make your social profiles stand out with fancy text, symbols &amp; decorations.
    </p>
    <p class="text-sm text-[var(--text-secondary)] max-w-2xl mx-auto mb-6 leading-relaxed">
      A free, privacy-first collection of online text tools for social media creators. Generate fancy Unicode fonts, browse 1000+ copy-paste symbols, explore Japanese kaomoji emoticons, and preview your bio across Instagram, TikTok, Discord, and more — all in one place, with no ads and no tracking.
    </p>
    <div class="max-w-md mx-auto flex gap-2">
      <input
        id="hero-search"
        type="text"
        placeholder="Search tools, symbols, kaomoji..."
        class="flex-1 px-4 py-3 rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)] text-[var(--text-primary)] placeholder:text-[var(--text-secondary)] focus:outline-none focus:ring-2 focus:ring-brand-500 dark:focus:ring-brand-400 transition-all"
      />
      <button
        id="hero-search-btn"
        class="px-5 py-3 rounded-xl bg-brand-500 text-white font-medium hover:bg-brand-600 active:scale-95 dark:bg-brand-400 dark:text-gray-900 dark:hover:bg-brand-300 transition-all"
      >
        Go
      </button>
    </div>
    <div id="search-results" class="hidden max-w-2xl mx-auto mt-4 text-left"></div>
  </section>

  <!-- Popular Tools -->
  <section class="px-4 pb-8">
    <h2 class="text-xl font-bold text-[var(--text-primary)] mb-4">Popular Tools</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
      <ToolCard
        href="/fancy-text-generator"
        title="Fancy Text Generator"
        description="30+ Unicode font styles"
        icon="✨"
      />
      <ToolCard
        href="/symbols"
        title="Symbol Library"
        description="1000+ aesthetic symbols"
        icon="💎"
      />
      <ToolCard
        href="/kaomoji"
        title="Kaomoji Collection"
        description="500+ Japanese emoticons"
        icon="(◕‿◕)"
      />
      <ToolCard
        href="/text-dividers"
        title="Text Dividers"
        description="200+ bio dividers"
        icon="─── ✦ ───"
      />
      <ToolCard
        href="/invisible-character"
        title="Invisible Characters"
        description="13 types explained"
        icon="⠀"
      />
      <ToolCard
        href="/bio-preview"
        title="Bio Preview Tool"
        description="Multi-platform preview"
        icon="📱"
      />
    </div>
  </section>

  <!-- Popular Symbols -->
  <section class="px-4 pb-8">
    <h2 class="text-xl font-bold text-[var(--text-primary)] mb-4">Popular Symbols</h2>
    <div class="space-y-4">
      {popularCategories.map((cat) => (
        <div class="p-4 rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)]">
          <h3 class="text-sm font-semibold text-[var(--text-secondary)] mb-2">
            {cat.icon} {cat.name}
          </h3>
          <div class="flex flex-wrap gap-2">
            {cat.symbols.slice(0, 12).map((sym) => {
              const ch = typeof sym === 'string' ? sym : sym.char;
              return (
                <button
                  class="w-10 h-10 flex items-center justify-center text-lg rounded-lg hover:bg-brand-100 dark:hover:bg-brand-900/30 active:scale-95 transition-all cursor-pointer"
                  data-copy={ch}
                >
                  {ch}
                </button>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- How It Works -->
  <section class="px-4 pb-8">
    <h2 class="text-xl font-bold text-[var(--text-primary)] mb-4">How It Works</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <div class="p-4 rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)] text-center">
        <div class="text-3xl mb-2">1️⃣</div>
        <h3 class="font-semibold text-[var(--text-primary)] mb-1">Type your text</h3>
        <p class="text-sm text-[var(--text-secondary)]">Enter any text in the input field.</p>
      </div>
      <div class="p-4 rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)] text-center">
        <div class="text-3xl mb-2">2️⃣</div>
        <h3 class="font-semibold text-[var(--text-primary)] mb-1">Choose a style</h3>
        <p class="text-sm text-[var(--text-secondary)]">Browse fonts, symbols, or decorations.</p>
      </div>
      <div class="p-4 rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)] text-center">
        <div class="text-3xl mb-2">3️⃣</div>
        <h3 class="font-semibold text-[var(--text-primary)] mb-1">Copy &amp; paste</h3>
        <p class="text-sm text-[var(--text-secondary)]">Click to copy and use anywhere.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="px-4 pb-8">
    <h2 class="text-xl font-bold text-[var(--text-primary)] mb-4">Frequently Asked Questions</h2>
    <div class="space-y-2">
      {[
        { q: 'Does fancy text work on all platforms?', a: 'Most Unicode text styles work on Instagram, TikTok, Discord, Twitter, and other major platforms. Some niche fonts may not render correctly on LinkedIn.' },
        { q: 'Are the generated characters really Unicode?', a: 'Yes! All our fancy text styles use standard Unicode characters, not custom fonts. This means they work in any app that supports Unicode.' },
        { q: 'Can I use these symbols in my username?', a: 'Some platforms allow Unicode in usernames, but many restrict it to standard characters. It depends on the platform\'s policies.' },
        { q: 'What are invisible characters used for?', a: 'Invisible characters can be used to create blank display names, add hidden spacing in bios, or format text in creative ways.' },
        { q: 'Is this tool free to use?', a: 'Yes, Social Text Toolkit is completely free with no sign-up required. All processing happens in your browser.' },
      ].map((item) => (
        <details class="group rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)] overflow-hidden">
          <summary class="px-4 py-3 cursor-pointer font-medium text-[var(--text-primary)] hover:bg-[var(--bg-secondary)] transition-colors flex justify-between items-center">
            <span>{item.q}</span>
            <svg class="w-4 h-4 text-[var(--text-secondary)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="px-4 pb-3 text-sm text-[var(--text-secondary)]">{item.a}</p>
        </details>
      ))}
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    'name': 'Social Text Toolkit',
    'url': 'https://example.com',
    'description': 'Free online text generator, symbol library, invisible characters, kaomoji & bio decorations for social media creators.',
    'applicationCategory': 'UtilitiesApplication',
    'operatingSystem': 'All',
    'offers': { '@type': 'Offer', 'price': '0', 'priceCurrency': 'USD' },
  })} />
</BaseLayout>

<script>
  document.querySelectorAll('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const text = btn.getAttribute('data-copy');
      if (window.copyToClipboard) window.copyToClipboard(text);
    });
  });
</script>

<script define:vars={{ categoriesJson: JSON.stringify(symbolCategories) }}>
  // Search index for homepage
  const symbolCategories = JSON.parse(categoriesJson);

  const toolPages = [
    { name: 'Fancy Text Generator', keywords: 'fancy text font style unicode bold italic script fraktur', url: '/fancy-text-generator', icon: '✨' },
    { name: 'Symbol Library', keywords: 'symbols hearts stars arrows aesthetic bio decoration', url: '/symbols', icon: '💎' },
    { name: 'Kaomoji Collection', keywords: 'kaomoji emoticon japanese happy sad cute love angry', url: '/kaomoji', icon: '(◕‿◕)' },
    { name: 'Text Dividers', keywords: 'divider separator bio line decoration', url: '/text-dividers', icon: '───' },
    { name: 'Invisible Character', keywords: 'invisible zero-width space blank empty copy', url: '/invisible-character', icon: '⠀' },
    { name: 'Bio Preview', keywords: 'bio preview instagram tiktok discord profile check', url: '/bio-preview', icon: '📱' },
    { name: 'Small Text', keywords: 'small tiny superscript subscript caps', url: '/small-text', icon: '↑' },
    { name: 'Upside Down Text', keywords: 'upside down flip reverse inverted', url: '/upside-down-text', icon: '↕' },
    { name: 'Glitch Text', keywords: 'glitch zalgo corrupt creepy scary distorted', url: '/glitch-text', icon: '⚡' },
    { name: 'Username Generator', keywords: 'username generator name aesthetic nick', url: '/username-generator', icon: '👤' },
  ];

  const searchInput = document.getElementById('hero-search');
  const searchBtn = document.getElementById('hero-search-btn');
  const searchResults = document.getElementById('search-results');

  function search(query) {
    const q = query.toLowerCase().trim();
    if (!q) { searchResults.classList.add('hidden'); return; }

    // Find matching tools
    const toolMatches = toolPages.filter(t =>
      t.name.toLowerCase().includes(q) || t.keywords.includes(q)
    );

    // Find matching symbols
    const symbolMatches = [];
    for (const cat of symbolCategories) {
      if (!cat.name.toLowerCase().includes(q) && !cat.id.includes(q)) continue;
      const chars = cat.symbols.slice(0, 5).map(s => typeof s === 'string' ? s : s.char);
      for (const ch of chars) {
        symbolMatches.push({ char: ch, category: cat.name, categoryId: cat.id });
      }
    }

    if (!toolMatches.length && !symbolMatches.length) {
      searchResults.classList.remove('hidden');
      searchResults.innerHTML = '<p class="text-sm text-[var(--text-secondary)] text-center py-4">No results found for "' + query + '"</p>';
      return;
    }

    let html = '';

    if (toolMatches.length) {
      html += '<h3 class="text-sm font-semibold text-[var(--text-primary)] mb-2">Tools</h3><div class="space-y-2 mb-4">';
      for (const tool of toolMatches) {
        html += '<a href="' + tool.url + '" class="flex items-center gap-3 p-3 rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)] hover:border-brand-300 dark:hover:border-brand-600 transition-all"><span class="text-xl">' + tool.icon + '</span><span class="font-medium text-[var(--text-primary)]">' + tool.name + '</span><svg class="w-4 h-4 text-[var(--text-secondary)] ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></a>';
      }
      html += '</div>';
    }

    if (symbolMatches.length) {
      html += '<h3 class="text-sm font-semibold text-[var(--text-primary)] mb-2">Symbols</h3><div class="flex flex-wrap gap-2 mb-2">';
      for (const sym of symbolMatches) {
        html += '<button class="symbol-item text-xl" data-copy="' + sym.char + '" title="Copy ' + sym.category + '" aria-label="Copy symbol">' + sym.char + '</button>';
      }
      html += '<a href="/symbols" class="inline-block text-xs text-brand-500 hover:text-brand-600 dark:text-brand-400 mt-1">View all →</a></div>';
    }

    searchResults.innerHTML = html;
    searchResults.classList.remove('hidden');

    // Attach copy handlers
    searchResults.querySelectorAll('[data-copy]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (window.copyToClipboard) window.copyToClipboard(btn.getAttribute('data-copy'));
      });
    });
  }

  searchBtn.addEventListener('click', () => search(searchInput.value));
  searchInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') search(searchInput.value); });
  searchInput.addEventListener('input', () => { if (searchInput.value.length >= 2) search(searchInput.value); else searchResults.classList.add('hidden'); });
</script>
