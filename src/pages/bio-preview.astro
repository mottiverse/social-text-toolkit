---
import ToolLayout from '../layouts/ToolLayout.astro';
import { platforms } from '../data/platforms.js';

const platformEntries = Object.entries(platforms);
const platformsJson = JSON.stringify(platforms);
---

<ToolLayout
  title="Bio Preview Tool"
  description="Preview how your bio text will look on Instagram, TikTok, Discord, Twitter/X, LinkedIn, and YouTube. Check character limits in real-time."
>
  <div slot="tool">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 px-4 pb-8">
    <!-- Input Area -->
    <div>
      <h2 class="text-lg font-bold text-[var(--text-primary)] mb-3" data-i18n="bioPreview.yourBio">Your Bio</h2>
      <textarea
        id="bio-input"
        rows="6"
        maxlength="1000"
        placeholder="Type your bio text here..."
        class="w-full px-4 py-3 rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)] text-[var(--text-primary)] placeholder:text-[var(--text-secondary)] focus:outline-none focus:ring-2 focus:ring-brand-500 dark:focus:ring-brand-400 resize-none transition-all"
      ></textarea>
      <p id="global-count" class="text-xs text-[var(--text-secondary)] mt-2">0 characters</p>
    </div>

    <!-- Preview Area -->
    <div>
      <h2 class="text-lg font-bold text-[var(--text-primary)] mb-3" data-i18n="bioPreview.preview">Preview</h2>

      <!-- Platform Tabs -->
      <div id="platform-tabs" class="flex gap-2 overflow-x-auto pb-3 scrollbar-hide">
        {platformEntries.map(([key, p], i) => (
          <button
            class="platform-tab whitespace-nowrap px-3 py-1.5 rounded-lg text-xs font-medium transition-all ${i === 0 ? 'bg-brand-500 text-white dark:bg-brand-400 dark:text-gray-900' : 'border border-[var(--border-color)] text-[var(--text-secondary)] hover:border-brand-300'}"
            data-platform={key}
          >{p.icon} {p.name}</button>
        ))}
      </div>

      <!-- Preview Card -->
      <div id="preview-card" class="rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)] overflow-hidden">
        <!-- Instagram Preview -->
        <div id="preview-ig" class="">
          <div class="px-4 pt-4 flex items-center gap-3">
            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-purple-500 via-pink-500 to-yellow-500 p-[2px] flex-shrink-0">
              <div class="w-full h-full rounded-full bg-[var(--bg-card)] flex items-center justify-center text-lg">👤</div>
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-semibold text-sm text-[var(--text-primary)]">username</div>
              <div id="preview-bio-ig" class="text-sm text-[var(--text-primary)] whitespace-pre-wrap break-words leading-relaxed mt-1 min-h-[40px]">Your bio will appear here...</div>
              <a href="#" class="text-xs text-[#00376b] dark:text-[#6ea8d3] font-semibold mt-1 inline-block">linkin.bio/username</a>
            </div>
          </div>
          <div class="px-4 py-2 flex gap-4 text-sm">
            <span class="font-semibold text-[var(--text-primary)]"><strong>0</strong> <span class="font-normal text-[var(--text-secondary)]">posts</span></span>
            <span class="font-semibold text-[var(--text-primary)]"><strong>0</strong> <span class="font-normal text-[var(--text-secondary)]">followers</span></span>
            <span class="font-semibold text-[var(--text-primary)]"><strong>0</strong> <span class="font-normal text-[var(--text-secondary)]">following</span></span>
          </div>
          <div class="px-4 py-2 border-t border-[var(--border-color)] flex justify-between items-center">
            <span id="ig-char-limit" class="text-xs text-[var(--text-secondary)]">0 / 150</span>
            <span id="ig-char-warning" class="text-xs text-red-500 hidden">Over character limit!</span>
          </div>
        </div>

        <!-- TikTok Preview -->
        <div id="preview-tt" class="hidden">
          <div class="px-4 pt-4 flex items-center gap-3">
            <div class="w-16 h-16 rounded-full bg-[#fe2c55] flex items-center justify-center text-white text-lg flex-shrink-0">🎵</div>
            <div class="flex-1 min-w-0">
              <div class="font-semibold text-base text-[var(--text-primary)]">@username</div>
              <div class="text-sm text-[var(--text-secondary)]">username</div>
              <div class="flex gap-3 mt-1 text-xs">
                <span class="font-semibold text-[var(--text-primary)]"><strong>0</strong> <span class="font-normal text-[var(--text-secondary)]">Following</span></span>
                <span class="font-semibold text-[var(--text-primary)]"><strong>0</strong> <span class="font-normal text-[var(--text-secondary)]">Followers</span></span>
                <span class="font-semibold text-[var(--text-primary)]"><strong>0</strong> <span class="font-normal text-[var(--text-secondary)]">Likes</span></span>
              </div>
              <div id="preview-bio-tt" class="text-sm text-[var(--text-primary)] whitespace-pre-wrap break-words leading-relaxed mt-2 min-h-[30px]">Your bio will appear here...</div>
              <a href="#" class="text-xs text-[#fe2c55] font-semibold mt-1 inline-block">🔗 linktr.ee/username</a>
            </div>
          </div>
          <div class="px-4 py-2 border-t border-[var(--border-color)] flex justify-between items-center">
            <span id="tt-char-limit" class="text-xs text-[var(--text-secondary)]">0 / 80</span>
            <span id="tt-char-warning" class="text-xs text-red-500 hidden">Over character limit!</span>
          </div>
        </div>

        <!-- Discord Preview -->
        <div id="preview-dc" class="hidden">
          <div class="bg-[#313338] dark:bg-[#1e1f22] text-white">
            <div class="h-20 rounded-t-xl bg-gradient-to-b from-[#5865f2] to-[#4752c4]"></div>
            <div class="px-4 -mt-10">
              <div class="w-20 h-20 rounded-full border-[6px] border-[#313338] dark:border-[#1e1f22] bg-[#5865f2] flex items-center justify-center text-2xl text-white flex-shrink-0">👤</div>
              <div class="mt-2">
                <div class="font-bold text-lg">Username</div>
                <div class="text-sm text-[#b5bac1]">username</div>
              </div>
              <div class="mt-3 pb-3 border-t border-[#3f4147] pt-3">
                <div class="text-xs text-[#b5bac1] font-semibold uppercase mb-1">ABOUT ME</div>
                <div id="preview-bio-dc" class="text-sm whitespace-pre-wrap break-words leading-relaxed min-h-[30px]">Your bio will appear here...</div>
              </div>
              <div class="pb-3 flex justify-between items-center">
                <span id="dc-char-limit" class="text-xs text-[#b5bac1]">0 / 190</span>
                <span id="dc-char-warning" class="text-xs text-[#f23f43] hidden">Over character limit!</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Generic Preview (Twitter, LinkedIn, YouTube) -->
        <div id="preview-generic" class="hidden">
          <div class="px-4 py-3 border-b border-[var(--border-color)] flex items-center gap-2">
            <span id="preview-icon" class="text-lg">{platforms.twitter.icon}</span>
            <span id="preview-name" class="font-semibold text-sm text-[var(--text-primary)]">{platforms.twitter.name}</span>
          </div>
          <div class="px-4 py-4">
            <p id="preview-bio-generic" class="text-sm text-[var(--text-primary)] whitespace-pre-wrap break-words leading-relaxed min-h-[60px]">Your bio will appear here...</p>
          </div>
          <div class="px-4 py-2 border-t border-[var(--border-color)] flex justify-between items-center">
            <span id="generic-char-limit" class="text-xs text-[var(--text-secondary)]">0 / 160</span>
            <span id="generic-char-warning" class="text-xs text-red-500 hidden">Over character limit!</span>
          </div>
        </div>
      </div>
    </div>
  </div>
  </div>
</ToolLayout>

<script define:vars={{ platformsJson }}>
  const platforms = JSON.parse(platformsJson);
  let activePlatform = 'instagram';

  const bioInput = document.getElementById('bio-input');
  const globalCount = document.getElementById('global-count');

  // All preview panels
  const previewIg = document.getElementById('preview-ig');
  const previewTt = document.getElementById('preview-tt');
  const previewDc = document.getElementById('preview-dc');
  const previewGeneric = document.getElementById('preview-generic');

  // Bio content elements
  const bioIg = document.getElementById('preview-bio-ig');
  const bioTt = document.getElementById('preview-bio-tt');
  const bioDc = document.getElementById('preview-bio-dc');
  const bioGeneric = document.getElementById('preview-bio-generic');

  // Character limits
  const charLimitIg = document.getElementById('ig-char-limit');
  const charLimitTt = document.getElementById('tt-char-limit');
  const charLimitDc = document.getElementById('dc-char-limit');
  const charLimitGeneric = document.getElementById('generic-char-limit');

  // Warnings
  const warnIg = document.getElementById('ig-char-warning');
  const warnTt = document.getElementById('tt-char-warning');
  const warnDc = document.getElementById('dc-char-warning');
  const warnGeneric = document.getElementById('generic-char-warning');

  // Generic header
  const previewIcon = document.getElementById('preview-icon');
  const previewName = document.getElementById('preview-name');

  const isSpecialPlatform = (key) => ['instagram', 'tiktok', 'discord'].includes(key);

  function hideAllPreviews() {
    [previewIg, previewTt, previewDc, previewGeneric].forEach(el => el.classList.add('hidden'));
  }

  function showPreview(key) {
    hideAllPreviews();
    switch (key) {
      case 'instagram': previewIg.classList.remove('hidden'); break;
      case 'tiktok': previewTt.classList.remove('hidden'); break;
      case 'discord': previewDc.classList.remove('hidden'); break;
      default:
        previewGeneric.classList.remove('hidden');
        if (platforms[key]) {
          previewIcon.textContent = platforms[key].icon;
          previewName.textContent = platforms[key].name;
        }
        break;
    }
  }

  function updateCharDisplay(el, warnEl, text, limit) {
    el.textContent = `${text.length} / ${limit}`;
    const over = text.length > limit;
    el.classList.toggle('text-red-500', over);
    if (!over) el.classList.add('text-[var(--text-secondary)]');
    if (warnEl) warnEl.classList.toggle('hidden', !over);
  }

  function updatePreview() {
    const text = bioInput.value;
    globalCount.textContent = `${text.length} characters`;

    const defaultText = 'Your bio will appear here...';
    const displayText = text || defaultText;

    // Update all bio previews
    if (bioIg) bioIg.textContent = displayText;
    if (bioTt) bioTt.textContent = displayText;
    if (bioDc) bioDc.textContent = displayText;
    if (bioGeneric) bioGeneric.textContent = displayText;

    // Update all char counts
    updateCharDisplay(charLimitIg, warnIg, text, platforms.instagram.bioLimit || 150);
    updateCharDisplay(charLimitTt, warnTt, text, platforms.tiktok.bioLimit || 80);
    updateCharDisplay(charLimitDc, warnDc, text, platforms.discord.bioLimit || 190);

    // Generic could be twitter/linkedin/youtube
    const genPlatform = platforms[activePlatform] || platforms.twitter;
    updateCharDisplay(charLimitGeneric, warnGeneric, text, genPlatform.bioLimit || 160);
  }

  function switchPlatform(platformKey) {
    activePlatform = platformKey;
    showPreview(platformKey);

    // Update generic preview name/icon if applicable
    if (!isSpecialPlatform(platformKey) && platforms[platformKey]) {
      previewIcon.textContent = platforms[platformKey].icon;
      previewName.textContent = platforms[platformKey].name;
    }

    // Update tab styles
    document.querySelectorAll('.platform-tab').forEach(tab => {
      if (tab.dataset.platform === platformKey) {
        tab.classList.add('bg-brand-500', 'text-white', 'dark:bg-brand-400', 'dark:text-gray-900');
        tab.classList.remove('border', 'border-[var(--border-color)]', 'text-[var(--text-secondary)]', 'hover:border-brand-300');
      } else {
        tab.classList.remove('bg-brand-500', 'text-white', 'dark:bg-brand-400', 'dark:text-gray-900');
        tab.classList.add('border', 'border-[var(--border-color)]', 'text-[var(--text-secondary)]', 'hover:border-brand-300');
      }
    });

    updatePreview();
  }

  document.querySelectorAll('.platform-tab').forEach(tab => {
    tab.addEventListener('click', () => switchPlatform(tab.dataset.platform));
  });

  bioInput.addEventListener('input', updatePreview);
  updatePreview();
</script>
