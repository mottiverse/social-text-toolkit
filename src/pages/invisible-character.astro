---
import ToolLayout from '../layouts/ToolLayout.astro';
import { invisibleChars } from '../data/invisible-chars.js';

const charsJson = JSON.stringify(invisibleChars);
---

<ToolLayout
  title="Invisible Character"
  description="Learn about 13 types of invisible and zero-width characters. Copy them for your social media bios, usernames, and creative text formatting."
>
  <section class="px-4 pb-8">
    <p class="text-sm text-[var(--text-secondary)] mb-4">
      Click any character to copy it. The dotted box represents the invisible character's position.
    </p>
    <div id="char-list" class="space-y-3">
      {invisibleChars.map((item) => (
        <div class="flex items-center gap-3 p-4 rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)]">
          <!-- Visual representation -->
          <button
            class="flex-shrink-0 w-12 h-12 rounded-lg border-2 border-dashed border-brand-300 dark:border-brand-600 flex items-center justify-center cursor-pointer hover:bg-brand-100 dark:hover:bg-brand-900/30 active:scale-95 transition-all"
            data-copy={item.char}
            title={`Copy ${item.name} (${item.unicode})`}
          >
            <span class="text-xs text-brand-400 dark:text-brand-500 select-none">{item.char === ' ' ? 'SPC' : item.unicode.replace('U+', '')}</span>
          </button>
          <!-- Info -->
          <div class="flex-1 min-w-0">
            <h3 class="font-semibold text-[var(--text-primary)] text-sm">{item.name}</h3>
            <p class="text-xs text-[var(--text-secondary)] mt-0.5">{item.description}</p>
            <div class="flex gap-2 mt-1.5">
              <span class="inline-block px-1.5 py-0.5 text-[10px] rounded bg-[var(--bg-secondary)] text-[var(--text-secondary)] font-mono">{item.unicode}</span>
              <span class="inline-block px-1.5 py-0.5 text-[10px] rounded bg-brand-100 dark:bg-brand-900/30 text-brand-600 dark:text-brand-400 truncate max-w-[200px]">{item.use}</span>
            </div>
          </div>
          <!-- Copy button -->
          <button
            class="btn-copy flex-shrink-0"
            data-copy={item.char}
          >Copy</button>
        </div>
      ))}
    </div>
  </section>
</ToolLayout>

<script>
  document.querySelectorAll('[data-copy]').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = btn.getAttribute('data-copy');
      if (window.copyToClipboard) window.copyToClipboard(text);
    });
  });
</script>
