---
import ToolLayout from '../layouts/ToolLayout.astro';
import { invisibleChars } from '../data/invisible-chars.js';

const charsJson = JSON.stringify(invisibleChars);
---

<ToolLayout
  title="Invisible Character"
  description="Learn about 13 types of invisible and zero-width characters. Copy them for your social media bios, usernames, and creative text formatting."
>
  <div slot="tool">
  <section class="px-4 pb-8">
    <!-- Intro Section -->
    <div class="mb-6 p-5 rounded-xl bg-brand-50 dark:bg-brand-900/20 border border-brand-200 dark:border-brand-800">
      <h3 class="text-base font-semibold text-[var(--text-primary)] mb-2">💡 What are invisible characters?</h3>
      <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
        Invisible characters are special Unicode characters that take up space or affect text layout without being visible. 
        They're used to create <strong>blank usernames</strong>, add <strong>hidden spacing</strong> in bios, create <strong>empty messages</strong>, 
        and format text in creative ways. Each type serves a different purpose — click any to copy it to your clipboard.
      </p>
    </div>

    <p class="text-sm text-[var(--text-secondary)] mb-4">
      Click any character to copy it. The dotted box represents the invisible character's position.
    </p>
    <div class="mb-6 p-4 rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)]">
      <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-2" data-i18n="compatibility">Platform Compatibility</h3>
      <div class="flex flex-wrap gap-2 text-xs">
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400" data-i18n="platform.instagram">✓ Instagram</span>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400" data-i18n="platform.tiktok">✓ TikTok</span>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400" data-i18n="platform.discord">✓ Discord</span>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400" data-i18n="platform.twitter">✓ Twitter/X</span>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400">⚠ YouTube</span>
        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400">✗ SMS</span>
      </div>
      <p class="text-xs text-[var(--text-secondary)] mt-2">Most invisible characters work on social platforms. SMS and plain-text emails may strip or convert them. Braille Pattern Blank and Hangul Filler are the most widely compatible.</p>
    </div>
    <div id="char-list" class="space-y-3">
      {invisibleChars.map((item) => (
        <div class="flex items-center gap-4 p-4 rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)] hover:border-brand-300 dark:hover:border-brand-600 transition-all group">
          <button class="flex-shrink-0 w-14 h-14 rounded-xl bg-brand-500 hover:bg-brand-600 dark:bg-brand-400 dark:hover:bg-brand-300 text-white font-bold text-sm flex items-center justify-center transition-all active:scale-95" data-copy={item.char} title={`Copy ${item.name}`}>
            Copy
          </button>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-semibold text-[var(--text-primary)] text-sm">{item.name}</h3>
              <span class="text-[10px] px-1.5 py-0.5 rounded bg-[var(--bg-secondary)] text-[var(--text-secondary)] font-mono">{item.unicode}</span>
            </div>
            <p class="text-xs text-[var(--text-secondary)]">{item.description}</p>
            <p class="text-xs text-brand-500 dark:text-brand-400 mt-1">💡 Use for: {item.use}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
  </div>
</ToolLayout>

<script>
  document.querySelectorAll('[data-copy]').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = btn.getAttribute('data-copy');
      if (window.copyToClipboard) window.copyToClipboard(text);
    });
  });
</script>
