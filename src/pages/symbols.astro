---
import ToolLayout from '../layouts/ToolLayout.astro';
import { symbolCategories } from '../data/symbols.js';

const categoriesJson = JSON.stringify(symbolCategories);
---

<ToolLayout
  title="Symbol Library"
  description="Browse and copy 1000+ aesthetic symbols for your social media bios, captions, and messages. Hearts, stars, arrows, flowers, and more."
>
  <!-- Search Bar -->
  <section class="px-4 pb-4">
    <div class="relative">
      <input
        id="search-input"
        type="text"
        placeholder="Search symbols..."
        class="w-full pl-10 pr-4 py-3 rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)] text-[var(--text-primary)] placeholder:text-[var(--text-secondary)] focus:outline-none focus:ring-2 focus:ring-brand-500 dark:focus:ring-brand-400 transition-all"
      />
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-[var(--text-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
    </div>
  </section>

  <!-- Category Tabs -->
  <section class="px-4 pb-4">
  <!-- Batch mode toggle and platform filter row -->
  <div class="flex flex-wrap items-center gap-2 pb-3">
    <button id="batch-mode-btn" class="px-3 py-1.5 rounded-full text-xs font-medium border border-[var(--border-color)] text-[var(--text-secondary)] hover:border-brand-300 dark:hover:border-brand-600 transition-all">
      ☐ Batch Select
    </button>
      <button class="platform-filter-btn whitespace-nowrap px-3 py-1.5 rounded-full text-xs font-medium bg-brand-500 text-white dark:bg-brand-400 dark:text-gray-900 transition-all" data-platform="all">All</button>
      <button class="platform-filter-btn whitespace-nowrap px-3 py-1.5 rounded-full text-xs font-medium border border-[var(--border-color)] text-[var(--text-secondary)] hover:border-brand-300 dark:hover:border-brand-600 transition-all" data-platform="ig">📸 IG</button>
      <button class="platform-filter-btn whitespace-nowrap px-3 py-1.5 rounded-full text-xs font-medium border border-[var(--border-color)] text-[var(--text-secondary)] hover:border-brand-300 dark:hover:border-brand-600 transition-all" data-platform="tt">🎵 TikTok</button>
      <button class="platform-filter-btn whitespace-nowrap px-3 py-1.5 rounded-full text-xs font-medium border border-[var(--border-color)] text-[var(--text-secondary)] hover:border-brand-300 dark:hover:border-brand-600 transition-all" data-platform="dc">💬 Discord</button>
      <button class="platform-filter-btn whitespace-nowrap px-3 py-1.5 rounded-full text-xs font-medium border border-[var(--border-color)] text-[var(--text-secondary)] hover:border-brand-300 dark:hover:border-brand-600 transition-all" data-platform="x">𝕏 X</button>
    </div>
    <p id="platform-note" class="text-[11px] text-[var(--text-secondary)] mt-1 hidden">All symbols use standard Unicode and work on all platforms. Some emoji rendering may differ by platform.</p>
    <div id="category-tabs" role="tablist" class="flex gap-2 overflow-x-auto pb-2 scrollbar-hide mt-1">
      <button
        class="tab-btn active whitespace-nowrap px-4 py-2 rounded-full text-sm font-medium bg-brand-500 text-white dark:bg-brand-400 dark:text-gray-900 transition-all"
        data-category="all"
        role="tab"
        aria-selected="true"
      >All</button>
      {symbolCategories.map((cat) => (
        <button
          class="tab-btn whitespace-nowrap px-4 py-2 rounded-full text-sm font-medium border border-[var(--border-color)] text-[var(--text-secondary)] hover:border-brand-300 hover:text-brand-500 dark:hover:border-brand-600 dark:hover:text-brand-400 transition-all"
          data-category={cat.id}
          role="tab"
          aria-selected="false"
        >{cat.icon} {cat.name}</button>
      ))}
    </div>
  </section>

  <!-- Symbol Grid -->
  <section class="px-4 pb-8">
    <div id="symbol-grid" class="grid grid-cols-4 sm:grid-cols-6 gap-2">
    </div>
    <p id="no-results" class="text-center text-[var(--text-secondary)] py-8 hidden">No symbols found</p>
  </section>

  <!-- Batch selection bar -->
  <div id="batch-bar" class="hidden fixed bottom-16 md:bottom-4 left-1/2 -translate-x-1/2 z-40 bg-[var(--bg-card)] border border-[var(--border-color)] rounded-2xl px-4 py-3 shadow-lg flex items-center gap-3 max-w-[95vw]">
    <span id="batch-count" class="text-sm font-medium text-[var(--text-primary)]">0 selected</span>
    <select id="batch-separator" class="text-xs rounded-lg border border-[var(--border-color)] bg-[var(--bg-secondary)] text-[var(--text-primary)] px-2 py-1">
      <option value="">No separator</option>
      <option value=" ">Space</option>
      <option value="\n">New line</option>
      <option value=", ">Comma</option>
      <option value=" | ">Pipe</option>
    </select>
    <button id="batch-copy-btn" class="btn-copy text-xs" disabled>Copy All</button>
    <button id="batch-clear-btn" class="px-2 py-1 rounded-lg text-xs text-[var(--text-secondary)] hover:text-red-500 transition-colors">Clear</button>
  </div>
</ToolLayout>

<script is:inline src="/scripts/tabs.js"></script>
<script define:vars={{ categoriesJson }}>
  const categories = JSON.parse(categoriesJson);
  let activeCategory = 'all';
  let activePlatform = 'all';
  let allSymbols = [];

  const searchInput = document.getElementById('search-input');
  const symbolGrid = document.getElementById('symbol-grid');
  const noResults = document.getElementById('no-results');
  const BATCH_SIZE = 60;
  let renderedCount = 0;

  // Precompute unique symbols once
  function buildSymbolList() {
    const seen = new Set();
    allSymbols = [];
    for (const cat of categories) {
      for (const sym of cat.symbols) {
        const ch = sym.char || sym; // backward compat with string format
        if (!seen.has(ch)) {
          seen.add(ch);
          allSymbols.push({ symbol: ch, id: sym.id || ch, categoryId: cat.id });
        }
      }
    }
  }

  // Create DOM element for a symbol
  function createSymbolEl(item) {
    const btn = document.createElement('button');
    btn.className = 'symbol-item';
    btn.dataset.copy = item.symbol;
    btn.dataset.category = item.categoryId;
    btn.title = 'Copy symbol';
    btn.setAttribute('aria-label', 'Copy symbol ' + item.symbol);
    btn.textContent = item.symbol;
    return btn;
  }

  // Render batch of symbols
  function renderBatch(start, count) {
    const fragment = document.createDocumentFragment();
    const end = Math.min(start + count, allSymbols.length);
    for (let i = start; i < end; i++) {
      fragment.appendChild(createSymbolEl(allSymbols[i]));
    }
    symbolGrid.appendChild(fragment);
    renderedCount = end;
  }

  // Filter visible symbols by category and search
  function applyFilters() {
    const query = searchInput.value.toLowerCase().trim();

    let visible = 0;
    for (const el of symbolGrid.children) {
      const inCategory = activeCategory === 'all' || el.dataset.category === activeCategory;
      const matchesSearch = !query || el.textContent.toLowerCase().includes(query);
      const show = inCategory && matchesSearch;
      el.classList.toggle('hidden', !show);
      if (show) visible++;
    }

    noResults.classList.toggle('hidden', visible > 0);
    return visible;
  }

  // Event delegation for symbol clicks
  symbolGrid.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-copy]');
    if (btn && window.copyToClipboard) {
      window.copyToClipboard(btn.dataset.copy);
    }
  });

  // Lazy load more on scroll
  const observer = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting && renderedCount < allSymbols.length) {
      renderBatch(renderedCount, BATCH_SIZE);
      applyFilters();
    }
  }, { rootMargin: '200px' });

  // Sentinel element for scroll detection
  const sentinel = document.createElement('div');
  sentinel.className = 'h-1';
  symbolGrid.after(sentinel);
  observer.observe(sentinel);

  // Re-observe sentinel after re-renders
  function recheckSentinel() {
    observer.unobserve(sentinel);
    sentinel.remove();
    symbolGrid.after(sentinel);
    observer.observe(sentinel);
  }

  // Debounced search
  let searchTimer;
  searchInput.addEventListener('input', () => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => applyFilters(), 50);
  });

  setupCategoryTabs('.tab-btn', (category) => {
    activeCategory = category;
    applyFilters();
  });

  // Initialize
  buildSymbolList();
  renderBatch(0, BATCH_SIZE);

  // Batch mode
  let batchMode = false;
  const selectedSymbols = new Set();
  const batchModeBtn = document.getElementById('batch-mode-btn');
  const batchBar = document.getElementById('batch-bar');
  const batchCount = document.getElementById('batch-count');
  const batchCopyBtn = document.getElementById('batch-copy-btn');
  const batchClearBtn = document.getElementById('batch-clear-btn');
  const batchSeparator = document.getElementById('batch-separator');

  function updateBatchUI() {
    const count = selectedSymbols.size;
    batchCount.textContent = count + ' selected';
    batchCopyBtn.disabled = count === 0;
    batchBar.classList.toggle('hidden', !batchMode || count === 0);
    symbolGrid.classList.toggle('cursor-pointer', !batchMode);
  }

  batchModeBtn.addEventListener('click', () => {
    batchMode = !batchMode;
    batchModeBtn.classList.toggle('bg-brand-500', batchMode);
    batchModeBtn.classList.toggle('text-white', batchMode);
    batchModeBtn.classList.toggle('dark:bg-brand-400', batchMode);
    batchModeBtn.classList.toggle('dark:text-gray-900', batchMode);
    batchModeBtn.textContent = batchMode ? '☑ Batch Mode On' : '☐ Batch Select';
    if (!batchMode) { selectedSymbols.clear(); }
    updateBatchUI();
  });

  // Override grid click for batch mode
  symbolGrid.addEventListener('click', (e) => {
    if (!batchMode) return;
    const btn = e.target.closest('[data-copy]');
    if (!btn) return;
    e.preventDefault();
    const sym = btn.dataset.copy;
    if (selectedSymbols.has(sym)) {
      selectedSymbols.delete(sym);
      btn.classList.remove('ring-2', 'ring-brand-500');
    } else {
      selectedSymbols.add(sym);
      btn.classList.add('ring-2', 'ring-brand-500');
    }
    updateBatchUI();
  }, true);

  batchCopyBtn.addEventListener('click', () => {
    const sep = batchSeparator.value.replace('\\n', '\n');
    const text = [...selectedSymbols].join(sep);
    if (window.copyToClipboard) window.copyToClipboard(text);
  });

  batchClearBtn.addEventListener('click', () => {
    selectedSymbols.clear();
    symbolGrid.querySelectorAll('.ring-2').forEach(el => el.classList.remove('ring-2', 'ring-brand-500'));
    updateBatchUI();
  });

  batchSeparator.addEventListener('change', updateBatchUI);

  // Platform filter buttons
  const platformNote = document.getElementById('platform-note');
  document.querySelectorAll('.platform-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activePlatform = btn.dataset.platform;
      document.querySelectorAll('.platform-filter-btn').forEach(b => {
        b.classList.remove('bg-brand-500', 'text-white', 'dark:bg-brand-400', 'dark:text-gray-900');
        if (!b.classList.contains('border')) {
          b.classList.add('border', 'border-[var(--border-color)]', 'text-[var(--text-secondary)]');
        }
      });
      btn.classList.add('bg-brand-500', 'text-white', 'dark:bg-brand-400', 'dark:text-gray-900');
      btn.classList.remove('border', 'border-[var(--border-color)]', 'text-[var(--text-secondary)]');
      platformNote.classList.toggle('hidden', activePlatform === 'all');
    });
  });
</script>
