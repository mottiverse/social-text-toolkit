---
import ToolLayout from '../layouts/ToolLayout.astro';
import { fontList, fontMaps } from '../data/fonts.js';
import { fontCompatibility } from '../data/platforms.js';

// Prepare font data for client (only what's needed)
const fontsForClient = fontList.map(f => ({
  id: f.id,
  name: f.name,
  map: fontMaps[f.id] || {},
}));
---

<ToolLayout title="Fancy Text Generator" description="Generate 30+ fancy text styles from Unicode fonts. Works on Instagram, TikTok, Discord, and more. Free online tool with one-click copy.">
  <div slot="tool">
    <!-- Input Area -->
    <div class="mb-6">
      <label for="text-input" class="block text-sm font-medium mb-2">Enter your text</label>
      <textarea
        id="text-input"
        rows="3"
        placeholder="Type something here..."
        class="w-full px-4 py-3 rounded-xl border border-[var(--border-color)] bg-[var(--bg-card)] text-[var(--text-primary)] placeholder:text-[var(--text-secondary)] focus:outline-none focus:ring-2 focus:ring-brand-500 dark:focus:ring-brand-400 transition-all resize-none text-lg"
      ></textarea>
    </div>

    <!-- Character Counter -->
    <div id="char-counter" class="hidden mb-6 grid grid-cols-2 sm:grid-cols-4 gap-2 text-sm">
      <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-[var(--bg-secondary)]">
        <span class="text-xs">IG:</span>
        <span id="counter-ig" class="font-mono">0/150</span>
      </div>
      <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-[var(--bg-secondary)]">
        <span class="text-xs">TT:</span>
        <span id="counter-tt" class="font-mono">0/80</span>
      </div>
      <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-[var(--bg-secondary)]">
        <span class="text-xs">DC:</span>
        <span id="counter-dc" class="font-mono">0/32</span>
      </div>
      <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-[var(--bg-secondary)]">
        <span class="text-xs">X:</span>
        <span id="counter-x" class="font-mono">0/160</span>
      </div>
    </div>

    <!-- Results -->
    <div id="results" class="space-y-3">
      <p class="text-[var(--text-secondary)] text-center py-8">Start typing above to see fancy text styles</p>
    </div>

    <!-- Show More -->
    <div id="show-more-container" class="hidden text-center mt-6">
      <button id="show-more-btn" class="px-6 py-2 rounded-xl border border-[var(--border-color)] text-[var(--text-secondary)] hover:text-brand-500 dark:hover:text-brand-400 hover:border-brand-300 dark:hover:border-brand-600 transition-all text-sm font-medium">
      </button>
    </div>
  </div>
</ToolLayout>

<script define:vars={{ fonts: fontsForClient, compatibility: fontCompatibility }}>
  const input = document.getElementById('text-input');
  const results = document.getElementById('results');
  const charCounter = document.getElementById('char-counter');
  const showMoreContainer = document.getElementById('show-more-container');
  const showMoreBtn = document.getElementById('show-more-btn');

  let showAll = false;
  const INITIAL_COUNT = 6;

  function convertText(text, fontMap) {
    let result = '';
    for (const char of text) {
      result += fontMap[char] || char;
    }
    return result;
  }

  function updateCounters(text) {
    const len = [...text].length;
    const counters = { ig: 150, tt: 80, dc: 32, x: 160 };
    for (const [key, limit] of Object.entries(counters)) {
      const el = document.getElementById('counter-' + key);
      if (!el) continue;
      const over = len > limit;
      el.textContent = len + '/' + limit;
      el.className = 'font-mono' + (over ? ' text-red-500 font-bold' : '');
    }
    charCounter.classList.toggle('hidden', len === 0);
  }

  function escapeHtml(str) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function escapeJs(str) {
    return str.replace(/\\/g, '\\\\').replace(/'/g, "\\'");
  }

  function renderResults(text) {
    if (!text) {
      results.innerHTML = '<p class="text-[var(--text-secondary)] text-center py-8">Start typing above to see fancy text styles</p>';
      showMoreContainer.classList.add('hidden');
      return;
    }

    const displayFonts = showAll ? fonts : fonts.slice(0, INITIAL_COUNT);
    let html = '';

    for (const font of displayFonts) {
      const converted = convertText(text, font.map);

      // Platform tags
      const comp = compatibility[font.id] || {};
      const platformLabels = { instagram: 'IG', tiktok: 'TikTok', discord: 'Discord', twitter: 'X' };
      let tagsHtml = '';
      for (const [platform, label] of Object.entries(platformLabels)) {
        const level = comp[platform] || 'full';
        const cfg = {
          full: { icon: '✓', cls: 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400' },
          partial: { icon: '⚠', cls: 'bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400' },
          limited: { icon: '✗', cls: 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400' },
        }[level] || { icon: '✓', cls: 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400' };
        tagsHtml += '<span class="inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded text-xs ' + cfg.cls + '">' + cfg.icon + ' ' + label + '</span>';
      }

      html += '<div class="tool-card">' +
        '<div class="flex items-center justify-between mb-2">' +
          '<span class="text-sm font-medium text-[var(--text-secondary)]">' + escapeHtml(font.name) + '</span>' +
          '<div class="flex items-center gap-1">' + tagsHtml + '</div>' +
        '</div>' +
        '<div class="text-xl mb-3 break-all leading-relaxed select-all">' + escapeHtml(converted) + '</div>' +
        '<div class="flex gap-2">' +
          '<button class="btn-copy" data-copy>Copy</button>' +
          '<button class="px-3 py-1.5 rounded-lg text-sm font-medium transition-all border border-[var(--border-color)] hover:border-brand-300 dark:hover:border-brand-600 hover:text-brand-500" data-fav>⭐</button>' +
        '</div>' +
      '</div>';
    }

    results.innerHTML = html;

    // Attach copy/fav handlers using data attributes to avoid inline JS escaping issues
    const cards = results.querySelectorAll('.tool-card');
    displayFonts.forEach((font, idx) => {
      const converted = convertText(text, font.map);
      const card = cards[idx];
      if (!card) return;
      card.querySelector('[data-copy]').onclick = () => copyToClipboard(converted);
      card.querySelector('[data-fav]').onclick = () => toggleFavorite(converted);
    });

    if (fonts.length > INITIAL_COUNT) {
      showMoreContainer.classList.toggle('hidden', showAll);
      showMoreBtn.textContent = showAll ? 'Show less' : 'Show all ' + fonts.length + ' styles';
    }
  }

  input.addEventListener('input', (e) => {
    renderResults(e.target.value);
    updateCounters(e.target.value);
  });

  showMoreBtn.addEventListener('click', () => {
    showAll = !showAll;
    renderResults(input.value);
  });

  input.focus();
</script>
